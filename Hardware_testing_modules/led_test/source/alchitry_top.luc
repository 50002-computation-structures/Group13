module alchitry_top (
    input clk,
    input rst_n,

    output io_led[3][8]
) {

    sig rst

    .clk(clk) {
        dff counter[27](#INIT(0), .rst(rst))
        dff led_state(#INIT(0), .rst(rst))
    }

    always {
        rst = ~rst_n

        counter.d = counter.q + 1
        led_state.d = led_state.q

        if (counter.q == 27d99_999_999) {
            counter.d = 0
            led_state.d = !led_state.q
        }

        io_led[0] = 0
        io_led[1] = 0
        io_led[2] = 0

        io_led[1][0] = led_state.q
    }
}