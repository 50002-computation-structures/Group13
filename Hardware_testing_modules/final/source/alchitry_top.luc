module alchitry_top (
    input clk,
    input rst_n,
    input io_dip[3][8],

    output io_led[3][8],
    output io_select[4]
) {
    sig rst
    sig mux_counter[16]
    sig digit_sel[2]

    seven_seg seg

    .clk(clk) {
        dff counter[16](.rst(rst))
        dff counterled[27](#INIT(0), .rst(rst))
        dff led_state(#INIT(0), .rst(rst))
    }

    always {
        rst = ~rst_n

        counter.d = counter.q + 1
        mux_counter = counter.q
        
        counterled.d = counterled.q + 1
        led_state.d = led_state.q

        // 1 second (100MHz)
        if (counterled.q == 27d99_999_999) {
            counterled.d = 0
            led_state.d = !led_state.q
        }
        
        // 상위 비트 2개로 4자리 선택
        digit_sel = mux_counter[15:14]

        io_led[0] = 8h00
        io_led[1] = 8h00
        io_led[2] = 8h00
        io_select = 4b1111
        seg.char = 4h0
        
        case (digit_sel) {
            2b00: 
                // 첫 번째 자리: 4
                seg.char = 4h4
                io_select[0] = 0
            
            2b01: 
                // 두 번째 자리: 1
                seg.char = 4h1
                io_select[1] = 0
            
            2b10: 
                // 세 번째 자리: 2
                seg.char = 4h2
                io_select[2] = 0
            
            2b11: 
                // 네 번째 자리: 5
                seg.char = 4h5
                io_select[3] = 0
            
        }

        io_led[1][6] = seg.segs[0]
        io_led[1][7] = seg.segs[1]
        io_led[2][0] = seg.segs[2]
        io_led[2][1] = seg.segs[3]
        io_led[2][2] = seg.segs[4]
        io_led[2][3] = seg.segs[5]
        io_led[2][4] = seg.segs[6]
        
        io_led[2][5] = led_state.q

        // decimal point 끄기
        io_led[0][7] = 0
                
        io_led[1][2] = io_dip[1][2] //up
        io_led[1][3] = io_dip[1][3] // right
        io_led[1][4] = io_dip[1][4] // left
        io_led[1][0] = io_dip[1][0] // down
    }
}