module alchitry_top (
    input clk,
    input rst_n,
    input io_dip[3][8],

    output io_led[3][8],
    output io_select[4]
) {
    sig rst
    sig mux_counter[16]
    sig digit_sel[2]

    seven_seg seg

    .clk(clk) {
        dff counter[16](.rst(rst))
        dff counterled[27](#INIT(0), .rst(rst))
        dff led_state(#INIT(0), .rst(rst))
    }

    always {
        rst = ~rst_n

        counter.d = counter.q + 1
        mux_counter = counter.q
        
        counterled.d = counterled.q + 1
        led_state.d = led_state.q

        if (counter.q == 27d99_999_999) {
            counter.d = 0
            led_state.d = !led_state.q
        }
        digit_sel = mux_counter[15:14]

        io_led[0] = 8h00
        io_led[1] = 8h00
        io_led[2] = 8h00
        io_select = 4b1111
        seg.char = 4h0
        
        case (digit_sel) {
            2b00: 
                seg.char = 4h4
                io_select[0] = 0
            
            2b01: 
                seg.char = 4h1
                io_select[1] = 0
            
            2b10: 
                seg.char = 4h2
                io_select[2] = 0
            
            2b11: 
                seg.char = 4h5
                io_select[3] = 0
            
        }

        io_led[0][0] = seg.segs[0]
        io_led[0][1] = seg.segs[1]
        io_led[0][2] = seg.segs[2]
        io_led[0][3] = seg.segs[3]
        io_led[0][4] = seg.segs[4]
        io_led[0][5] = seg.segs[5]
        io_led[0][6] = seg.segs[6]
        io_led[1][0] = led_state.q

        io_led[0][7] = 0
        
        io_led[1][6] = io_dip[1][6]
    }
}